import android.content.Intent;
import android.content.Context;
import bsh.This;

/*───────────────────────────────────────────────────────────────
shareText(String text, String labelOrPackage)
**Shares Text to Specific App**
Creates an Intent to share text. If a package name is provided,
it targets that specific app; otherwise, it shows the system
chooser.

Arguments:

* text → The string content to be shared.
* labelOrPackage → The package ID of the target app or app label (e.g., "com.whatsapp").
Pass null or empty string for the system chooser.

Example:
// Share to WhatsApp
shareText("Hello from Tasker!", "com.whatsapp");

// Open general share menu
shareText("Check this out!", null);
───────────────────────────────────────────────────────────────*/
public void shareText(String text, String labelOrPackage) {
	Intent intent = new Intent(Intent.ACTION_SEND);
	intent.setType("text/plain");
	intent.putExtra(Intent.EXTRA_TEXT, text);
	intent.addFlags(Intent.FLAG_ACTIVITY_NEW_TASK);

	/* Target a specific app if package is provided */
	if (labelOrPackage != null && !labelOrPackage.equals("")) {
		This a11Y = tasker.getJavaVariable("a11Y");
		This pm = a11Y.packageManager;
		String pkg = pm.resolvePackage(labelOrPackage);
		intent.setPackage(labelOrPackage);
		context.startActivity(intent);
		return;
	}

	/* Otherwise, create a chooser for the user */
	Intent chooser = Intent.createChooser(intent, "Share via");
	chooser.addFlags(Intent.FLAG_ACTIVITY_NEW_TASK);
	context.startActivity(chooser);


}

shareText(String text) {
	return shareText(text, null);
}